# Frontend Environment Variables

# API Base URL
VITE_API_URL=/hotel-sanmiguel/api

# Hotel Information
VITE_HOTEL_NAME=Casa del Sol
VITE_HOTEL_PHONE=+52 (415) 123-4567
VITE_HOTEL_EMAIL=reservas@casadelsol.mx
VITE_HOTEL_ADDRESS=Calle Aldama 12, Centro Histórico, San Miguel de Allende, Gto. 37700

# Google Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps API Key (optional)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Development Mode
VITE_DEV_MODE=true